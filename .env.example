# server
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# llm — primary gemini (cheap, live), fallback deepseek v4 pro via openrouter
# leave both empty to run in deterministic mock mode (demo still works)
GEMINI_API_KEY=
LLM_PRIMARY_MODEL=gemini-3.1-flash-lite
OPENROUTER_API_KEY=
LLM_FALLBACK_MODEL=deepseek/deepseek-v4-pro
# which runs text first: "gemini" (default) or "openrouter". set openrouter to run text on
# openrouter's model (LLM_FALLBACK_MODEL) — useful if the gemini key is capped. images still need gemini.
LLM_PROVIDER=gemini

# sources — reddit + news need no key. youtube needs this (part of the source set)
YOUTUBE_API_KEY=
# crypto news rss feeds (comma-separated, no key) — edit/extend freely
NEWS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed,https://bitcoinmagazine.com/feed
# reddit: public json 403s on cloud ips. make a free "script" app at reddit.com/prefs/apps
# and paste id+secret so reddit works on railway (without these it only works on local/residential)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# grounding is core (not optional) — it keeps content accurate + low-hallucination.
# gemini uses its built-in google-search grounding; tavily is only the fallback for the gpt-oss path.
SEARCH_API_KEY=

# shared secret so only our frontend proxy can hit this backend
PROXY_SECRET=

# ai thumbnails (bonus, optional) — falls back to styled covers if r2 not set.
# nano banana 2 (uses GEMINI_API_KEY). drop 3-5 photos of the creator in backend/assets/ for his face.
IMAGE_MODEL=gemini-3.1-flash-image-preview
REFERENCE_DIR=assets
# cloudflare r2 (s3-compatible) to host generated thumbnails
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
